{
  "entities": {
    "InventoryItem": {
      "title": "Inventory Item",
      "description": "A single snack inventory record generated by the OCR system.",
      "type": "object",
      "properties": {
        "itemName": {
          "type": "string"
        },
        "expirationDate": {
          "type": "string",
          "format": "date",
          "description": "Can be null or omitted if uncertain"
        },
        "quantity": {
          "type": "integer"
        },
        "createdBy": {
          "type": "string"
        },
        "createdAt": {
          "type": "object"
        }
      },
      "required": ["itemName", "quantity", "createdBy", "createdAt"]
    }
  },
  "firestore": {
    "inventory/{itemId}": {
      "schema": {
        "$ref": "#/entities/InventoryItem"
      },
      "description": "List of scanned inventory items."
    }
  }
}
